<%- include('../partials/header', { pageTitle, currentType }) %>

<div class="layui-container m-top">
  <div class="layui-card login-card">
    <div class="layui-card-header">GitHub 授权登录</div>
    <div class="layui-card-body">
      <div class="layui-text" style="margin-bottom: 16px;">
        <p>本站已关闭站内注册与账号密码登录，仅支持 GitHub OAuth 授权登录。</p>
      </div>

      <% if (error) { %>
        <div class="layui-form-item">
          <div class="layui-font-red"><%= error %></div>
        </div>
      <% } %>

      <% if (githubEnabled) { %>
        <a class="layui-btn layui-btn-fluid xi-red-btn" href="/index/login/github?redirect=<%= encodeURIComponent(redirect) %>">
          使用 GitHub 账号登录
        </a>
      <% } else { %>
        <div class="layui-form-item">
          <div class="layui-font-orange">管理员尚未配置 GitHub OAuth，请先在 `.env` 中设置 `GITHUB_OAUTH_CLIENT_ID / GITHUB_OAUTH_CLIENT_SECRET`。</div>
        </div>
      <% } %>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
