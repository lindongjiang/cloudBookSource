<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
    <title><%= (seo && seo.title) ? seo.title : pageTitle %></title>
    <% if (seo && seo.description) { %><meta name="description" content="<%= seo.description %>" /><% } %>
    <% if (seo && seo.keywords) { %><meta name="keywords" content="<%= seo.keywords %>" /><% } %>
    <% if (seo && seo.robots) { %><meta name="robots" content="<%= seo.robots %>" /><% } %>
    <% if (seo && seo.canonical) { %><link rel="canonical" href="<%= seo.canonical %>" /><% } %>
    <% if (seo && seo.title) { %><meta property="og:title" content="<%= seo.title %>" /><% } %>
    <% if (seo && seo.description) { %><meta property="og:description" content="<%= seo.description %>" /><% } %>
    <% if (seo && seo.ogType) { %><meta property="og:type" content="<%= seo.ogType %>" /><% } %>
    <% if (seo && seo.canonical) { %><meta property="og:url" content="<%= seo.canonical %>" /><% } %>
    <% if (seo && seo.ogImage) { %><meta property="og:image" content="<%= seo.ogImage %>" /><% } %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/layui@2.9.22/dist/css/layui.css" />
    <link rel="stylesheet" href="/static/css/common.css?v=2" />
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/layui@2.9.22/dist/layui.min.js"></script>
    <% if (seo && seo.jsonLd) { %>
      <script type="application/ld+json"><%- JSON.stringify(seo.jsonLd) %></script>
    <% } %>
  </head>
  <body class="mode-<%= siteMode %>">
    <div class="header">
      <div class="layui-container">
        <div class="logo">
          <a href="/yuedu/index/index.html" title="<%= siteMeta.siteName %>" class="logo-main">
            <img src="<%= siteMeta.logoUrl %>" alt="<%= siteMeta.siteName %> 图标" />
            <span><%= siteMeta.siteName %></span>
          </a>
          <a class="mode-switch-pill" href="<%= siteMeta.modeSwitch.href %>" title="切换到 <%= siteMeta.modeSwitch.label %>">
            <img src="<%= siteMeta.modeSwitch.logoUrl %>" alt="<%= siteMeta.modeSwitch.label %> 图标" />
            <span><%= siteMeta.modeSwitch.label %></span>
          </a>
        </div>
        <i class="layui-icon layui-icon-template-1 mobile-icon"></i>
        <div class="nav">
          <ul class="layui-nav menunav">
            <li class="layui-nav-item <%= currentType === 'index' ? 'layui-this' : '' %>"><a href="/yuedu/index/index.html">首页</a></li>
            <li class="layui-nav-item <%= currentType === 'tools' ? 'layui-this' : '' %>"><a href="/yuedu/tools/index.html">工具</a></li>
            <li class="layui-nav-item <%= currentType === 'install' ? 'layui-this' : '' %>"><a href="/yuedu/install/index.html"><%= siteMeta.installNavLabel %></a></li>
            <li class="layui-nav-item <%= currentType === 'activation' ? 'layui-this' : '' %>"><a href="/yuedu/activation/index.html"><%= siteMeta.activationNavLabel %></a></li>
            <li class="layui-nav-item"><a target="_blank" href="<%= siteMeta.topExternalUrl %>"><%= siteMeta.topExternalLabel %></a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="usernav">
      <div class="layui-container">
        <div class="homepath">
          <span class="layui-breadcrumb">
            <a href="/yuedu/index/index.html">首页</a>
            <% if (currentType && currentType !== 'none' && currentType !== 'index') { %>
              <a><%= pageLabelMap[currentType] || '页面' %></a>
            <% } %>
          </span>
        </div>
        <div class="user">
          <span class="layui-breadcrumb" lay-separator="|">
            <% if (currentUser) { %>
              <a><%= currentUser.displayName %> (UID:<%= currentUser.uid %>)</a>
              <a href="/index/logout">退出</a>
            <% } else { %>
              <a href="/index/login/login.html?redirect=<%= encodeURIComponent(requestUrl) %>">登录</a>
            <% } %>
          </span>
        </div>
      </div>
    </div>

    <div class="main">
      <div class="layui-container">
        <div class="layui-panel" style="padding: 0px;">
          <div class="layui-tab layui-tab-brief" style="margin: 0;">
            <ul class="layui-tab-title" id="navsub" style="text-align: center; height: auto !important; white-space: normal !important;">
              <li class="<%= currentType === 'index' ? 'layui-this' : '' %>"><a href="/yuedu/index/index.html">首页</a></li>
              <li class="<%= currentType === 'shuyuan' ? 'layui-this' : '' %>"><a href="/yuedu/shuyuan/index.html">书源</a></li>
              <li class="<%= currentType === 'shuyuans' ? 'layui-this' : '' %>"><a href="/yuedu/shuyuans/index.html">书源合集</a></li>
              <li class="<%= currentType === 'install' ? 'layui-this' : '' %>"><a href="/yuedu/install/index.html"><%= siteMeta.installNavLabel %></a></li>
              <li class="<%= currentType === 'activation' ? 'layui-this' : '' %>"><a href="/yuedu/activation/index.html"><%= siteMeta.activationNavLabel %></a></li>
              <li><a target="_blank" href="<%= siteMeta.topExternalUrl %>"><%= siteMeta.topExternalLabel %></a></li>
              <% if (siteMode === 'ios') { %>
                <li><a href="/yuedu/index/index.html#help-request-panel">求书源</a></li>
              <% } %>
            </ul>
          </div>
        </div>
      </div>
