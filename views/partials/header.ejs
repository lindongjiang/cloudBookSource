<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
    <title><%= pageTitle %></title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/layui@2.9.22/dist/css/layui.css" />
    <link rel="stylesheet" href="/static/css/common.css?v=1" />
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/layui@2.9.22/dist/layui.min.js"></script>
  </head>
  <body>
    <div class="header">
      <div class="layui-container">
        <div class="logo">
          <a href="/" title="源仓库">源仓库</a>
        </div>
        <i class="layui-icon layui-icon-template-1 mobile-icon"></i>
        <div class="nav">
          <ul class="layui-nav menunav">
            <li class="layui-nav-item layui-this"><a href="/">资源中心</a></li>
            <li class="layui-nav-item"><a href="/article">文章列表</a></li>
            <li class="layui-nav-item"><a target="_blank" href="https://example.com">地址发布页(防丢)</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="usernav">
      <div class="layui-container">
        <div class="homepath">
          <span class="layui-breadcrumb">
            <a href="/">首页</a>
            <a href="/yuedu/index/index.html">阅读</a>
            <% if (currentType && currentType !== 'none' && currentType !== 'index') { %>
              <a><%= typeConfigMap[currentType] ? typeConfigMap[currentType].label : '页面' %></a>
            <% } %>
          </span>
        </div>
        <div class="user">
          <span class="layui-breadcrumb" lay-separator="|">
            <% if (currentUser) { %>
              <a><%= currentUser.displayName %> (UID:<%= currentUser.uid %>)</a>
              <a href="/index/logout">退出</a>
            <% } else { %>
              <a href="/index/login/login.html?redirect=<%= encodeURIComponent(requestUrl) %>">登录</a>
            <% } %>
          </span>
        </div>
      </div>
    </div>

    <div class="main">
      <div class="layui-container">
        <div class="layui-panel" style="padding: 0px;">
          <div class="layui-tab layui-tab-brief" style="margin: 0;">
            <ul class="layui-tab-title" id="navsub" style="text-align: center; height: auto !important; white-space: normal !important;">
              <li class="<%= currentType === 'index' ? 'layui-this' : '' %>"><a href="/yuedu/index/index.html">阅读</a></li>
              <li class="<%= currentType === 'shuyuan' ? 'layui-this' : '' %>"><a href="/yuedu/shuyuan/index.html">书源</a></li>
              <li class="<%= currentType === 'shuyuans' ? 'layui-this' : '' %>"><a href="/yuedu/shuyuans/index.html">书源合集</a></li>
              <li class="<%= currentType === 'rss' ? 'layui-this' : '' %>"><a href="/yuedu/rss/index.html">订阅源</a></li>
              <li class="<%= currentType === 'rsss' ? 'layui-this' : '' %>"><a href="/yuedu/rsss/index.html">订阅源合集</a></li>
              <li class="<%= currentType === 'tools' ? 'layui-this' : '' %>"><a href="/yuedu/tools/index.html">其他</a></li>
            </ul>
          </div>
        </div>
      </div>
